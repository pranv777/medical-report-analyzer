# ============================================================
# .env.example — copy to .env and fill in your values
# ============================================================

# ── LLM Provider ───────────────────────────────────────────
# Ollama (local, default)
MEDICAL_RAG__RAG__OLLAMA_BASE_URL=http://localhost:11434
MEDICAL_RAG__RAG__LLM_MODEL=llama3

# HuggingFace (optional — for hosted inference)
# MEDICAL_RAG__RAG__LLM_PROVIDER=huggingface
# HUGGINGFACE_TOKEN=hf_your_token_here

# OpenAI-compatible (optional)
# OPENAI_API_KEY=sk-your-key-here

# ── Embeddings ─────────────────────────────────────────────
# Override embedding model via env
# MEDICAL_RAG__KNOWLEDGE_BASE__EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# ── Paths ──────────────────────────────────────────────────
MEDICAL_RAG__KNOWLEDGE_BASE__CHROMADB_PATH=data/knowledge_base/chroma_db
MEDICAL_RAG__PROJECT__LOG_LEVEL=INFO

# ── GPU ────────────────────────────────────────────────────
# Set to true if CUDA is available
MEDICAL_RAG__EXTRACTION__USE_GPU=false

# ── MLflow ─────────────────────────────────────────────────
MEDICAL_RAG__EVALUATION__MLFLOW__TRACKING_URI=logs/mlflow
MLFLOW_TRACKING_URI=logs/mlflow
